# Neon Postgres connection string (use the pooled connection for serverless)
# Example: postgres://USER:PASSWORD@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URI=

# Secret used to sign Payload auth tokens. Generate with: openssl rand -hex 32
PAYLOAD_SECRET=

# Public URL of the deployed site (used for admin + SEO/OG)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Email (Resend). Without RESEND_API_KEY, contact-form mails are logged to the console.
RESEND_API_KEY=
# Verified sender domain in Resend (From address).
EMAIL_FROM=noreply@anna-saxo.de
# Where contact-form notifications go. If empty, the SiteSettings email is used.
CONTACT_RECIPIENT=
